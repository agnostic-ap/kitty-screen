# Local macOS signing and notarization settings.
# Copy this file to .env and fill in one notarization method.

# Required for signed macOS builds.
APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# Required when using APPLE_ID notarization. Also useful as a reference.
APPLE_TEAM_ID="TEAMID"

# Notarization method A: App Store Connect API key (recommended).
# APPLE_API_ISSUER="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# APPLE_API_KEY="XXXXXXXXXX"
# APPLE_API_KEY_PATH="/absolute/path/to/AuthKey_XXXXXXXXXX.p8"

# Optional when the Apple ID has access to multiple providers.
# APPLE_PROVIDER_SHORT_NAME="provider-short-name"

# Notarization method B: Apple ID app-specific password.
# APPLE_ID="you@example.com"
# APPLE_PASSWORD="xxxx-xxxx-xxxx-xxxx"
